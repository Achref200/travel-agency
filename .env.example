# ── Local development environment ──────────────────────────────────────────
# Copy to `.env` and fill in. Never commit real secrets.

# Database (SQLite for local dev; use a Postgres URL in production)
DATABASE_URL="file:./dev.db"

# Public site URL (used for canonical URLs, sitemaps, OG tags)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Cloudinary — set to enable automatic image optimisation/CDN delivery.
# Leave empty to serve source images directly (site still works).
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=""

# ── Admin dashboard ─────────────────────────────────────────────────────────
# Seeded into the AdminUser table when you run `npx prisma db seed`.
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="change-me"
# Secret used to sign admin session cookies. Use a long random string.
ADMIN_SESSION_SECRET="change-me-to-a-long-random-string"
