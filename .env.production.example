# ── PRODUCTION ENVIRONMENT (Contabo / Docker Compose) ───────────────────────
# Copy to `.env` on the server, then fill in real values:
#     cp .env.production.example .env
# Keep the resulting `.env` private — it is git-ignored and never baked into
# the Docker image.

# Your domain WITHOUT protocol — Caddy uses it for automatic HTTPS.
DOMAIN="yourdomain.com"

# Public site URL WITH protocol, no trailing slash.
# Inlined at build time, so it must be correct before `docker compose build`.
NEXT_PUBLIC_SITE_URL="https://yourdomain.com"

# SQLite database file inside the container (mapped to the db-data volume).
DATABASE_URL="file:/data/prod.db"

# ── Admin account — created / updated automatically on every boot ────────────
ADMIN_EMAIL="marwen-travel@agency.com"
ADMIN_PASSWORD="MarwenTravel@2026"

# Secret that signs admin session cookies. GENERATE A FRESH ONE and keep it
# stable (changing it logs everyone out):
#     openssl rand -base64 48
ADMIN_SESSION_SECRET="REPLACE_WITH_A_LONG_RANDOM_STRING"

# ── Cloudinary (optional image CDN / optimisation) ──────────────────────────
# Leave empty to serve source images directly / store uploads on the disk volume.
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=""
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=""
